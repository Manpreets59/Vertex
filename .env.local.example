# Convex Configuration
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
VERTEX_CONVEX_INTERNAL_KEY=sk-your-internal-key-here

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
CLERK_SECRET_KEY=sk_test_your-key-here
CLERK_JWT_ISSUER_DOMAIN=https://your-domain.clerk.accounts.dev

# AI APIs
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-key-here
# ANTHROPIC_API_KEY=your-anthropic-key-here  # Optional if using Claude

# Firecrawl Web Scraping
FIRECRAWL_API_KEY=fc-your-firecrawl-key-here

# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn-here@your-org.ingest.sentry.io/your-project-id
SENTRY_AUTH_TOKEN=sntrys_your-sentry-token-here
